rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'wazooshop@gmail.com' || 
              request.auth.token.email == 'Wazooshop@gmail.com' || 
              request.auth.token.email.lower() == 'wazooshop@gmail.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Global site configuration
    match /configs/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Page-specific content
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(pageId);
    }

    // Community Blog Posts
    match /blog_posts/{postId} {
      allow get: if (resource == null) || resource.data.status == 'published' || isAdmin();
      allow list: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin() && isValidId(postId);
    }
  }
}
