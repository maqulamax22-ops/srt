{
  "entities": {
    "SiteConfig": {
      "title": "Site Configuration",
      "description": "Global settings for the website",
      "type": "object",
      "properties": {
        "logoText": { "type": "string" },
        "footerText": { "type": "string" },
        "instagramLink": { "type": "string" },
        "navigation": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "path": { "type": "string" }
            }
          }
        }
      }
    },
    "PageContent": {
      "title": "Page Content",
      "description": "Content for each page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["hero", "text-cta", "tools", "custom"] },
              "data": { "type": "object" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "configs/site": {
      "schema": "SiteConfig",
      "description": "Global site configuration"
    },
    "pages/{pageId}": {
      "schema": "PageContent",
      "description": "Page-specific content sections"
    }
  }
}
